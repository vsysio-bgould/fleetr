# ============================================================
# Fleetr environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# ---- Application ------------------------------------------

# Base URL of the app. Used for generating fleet join links in API responses.
# No trailing slash.
APP_URL=http://localhost:3000

# Node environment. Set automatically by Next.js in most cases.
# Override to "test" when running the test suite against test services.
NODE_ENV=development

# ---- Database ---------------------------------------------

# MySQL connection string (Prisma).
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Dev default matches docker-compose.yml service.
DATABASE_URL=mysql://fleetr:fleetr@localhost:3306/fleetr

# ---- Redis ------------------------------------------------

# Redis connection string (BullMQ + optional caching).
# Dev default matches docker-compose.yml service.
REDIS_URL=redis://localhost:6379

# ---- Auth / Cookies ---------------------------------------

# Secret used to sign httpOnly session cookies.
# Generate with: openssl rand -hex 32
# Must be at least 32 characters. Rotate by updating this value —
# all existing sessions will be invalidated.
COOKIE_SECRET=replace-with-a-random-32-char-string

# ---- ESI OAuth --------------------------------------------
# Register your app at https://developers.eveonline.com
# Set the callback URL to: ${APP_URL}/api/v1/auth/callback
# Required scopes to register: esi-fleets.read_fleet.v1

ESI_CLIENT_ID=your_esi_client_id
ESI_CLIENT_SECRET=your_esi_client_secret

# Must match exactly what is registered in the ESI app settings.
ESI_CALLBACK_URL=http://localhost:3000/api/v1/auth/callback

# ---- Cron -------------------------------------------------

# Secret for the internal cron trigger endpoint (/api/v1/internal/cron).
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-random-32-char-string

# ---- Admin bootstrap --------------------------------------

# EVE character ID of the first operator. Run "npm run db:seed" after setting this.
SEED_OPERATOR_CHARACTER_ID=12345678

# ---- PartyKit ---------------------------------------------

# Host for the PartyKit server. Browser clients connect to this directly.
# Local dev: set by "npx partykit dev" (default port 1999).
# Production: your PartyKit deployment host (e.g. fleetr.your-username.partykit.dev)
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999

# Shared secret for authenticating internal API calls from the PartyKit server.
# Generate with: openssl rand -hex 32
# Must match the PARTYKIT_SECRET configured in the PartyKit server environment.
PARTYKIT_SECRET=replace-with-a-random-32-char-string

# PartyKit project name. Required for "npx partykit deploy" (cloud deployment).
# Leave empty for local dev.
PARTYKIT_PROJECT=

# ---- YouTube Data API -------------------------------------
# Used to validate submitted YouTube URLs and fetch video metadata
# (title, thumbnail, duration, embeddable status) at submission time.
# Create a key at https://console.cloud.google.com — enable "YouTube Data API v3".
YOUTUBE_API_KEY=your_youtube_data_api_key

# ---- SoundCloud (optional) --------------------------------
# Required only if you plan to use the SoundCloud API beyond the
# public oEmbed endpoint. Leave empty — oEmbed validation works without it.
SOUNDCLOUD_CLIENT_ID=

# ---- Logging ----------------------------------------------
# Pino log level: trace | debug | info | warn | error | fatal
# Default: info
LOG_LEVEL=info

# ---- Token expiry (optional) ------------------------------
# Lifetime of issued API tokens in days. Default: 30.
# API_TOKEN_EXPIRY_DAYS=30

# ============================================================
# Test environment
# ============================================================
# When running tests locally, override DATABASE_URL and REDIS_URL
# to point at the test services (docker compose --profile test up -d):
#
#   DATABASE_URL=mysql://fleetr:fleetr@localhost:3307/fleetr_test
#   REDIS_URL=redis://localhost:6380
#
# The CI pipeline sets these automatically via workflow env vars.
# ============================================================
