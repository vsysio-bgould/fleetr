# ============================================================
# Local Docker Compose environment — copy to .env.local
#   cp .env.local.example .env.local
# Then fill in the four secrets marked REQUIRED below.
# ============================================================

# ---- Application ------------------------------------------

# Public URL the browser uses to reach the app. Keep localhost:3000 for local.
APP_URL=http://localhost:3000

NODE_ENV=development

# ---- Database ---------------------------------------------
# "mysql" is the Docker Compose service name — do NOT change to localhost.
DATABASE_URL=mysql://fleetr:fleetr@mysql:3306/fleetr

# ---- Redis ------------------------------------------------
# "redis" is the Docker Compose service name.
REDIS_URL=redis://redis:6379

# ---- Auth / Cookies ---------------------------------------
# REQUIRED — generate with: openssl rand -hex 32
COOKIE_SECRET=replace-with-a-random-32-char-string

# ---- ESI OAuth --------------------------------------------
# REQUIRED — register at https://developers.eveonline.com
# Callback URL to register: http://localhost:3000/api/v1/auth/callback
ESI_CLIENT_ID=your_esi_client_id
ESI_CLIENT_SECRET=your_esi_client_secret
ESI_CALLBACK_URL=http://localhost:3000/api/v1/auth/callback

# ---- Cron -------------------------------------------------
# REQUIRED — generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-random-32-char-string

# ---- Admin bootstrap --------------------------------------
SEED_OPERATOR_CHARACTER_ID=12345678

# ---- PartyKit ---------------------------------------------
# The browser connects to PartyKit directly, so this must be localhost:1999.
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999

# Next.js broadcasts to PartyKit over the Docker network.
# "partykit" is the compose service name - do NOT change to localhost.
PARTYKIT_INTERNAL_URL=http://partykit:1999

# PartyKit callbacks to the Next.js app go through the Docker network.
# "app" is the compose service name — do NOT change to localhost.
PARTYKIT_APP_URL=http://app:3000

# REQUIRED — generate with: openssl rand -hex 32
PARTYKIT_SECRET=replace-with-a-random-32-char-string

# ---- YouTube Data API -------------------------------------
YOUTUBE_API_KEY=your_youtube_data_api_key

# ---- SoundCloud (optional) --------------------------------
SOUNDCLOUD_CLIENT_ID=

# ---- Logging ----------------------------------------------
LOG_LEVEL=info
